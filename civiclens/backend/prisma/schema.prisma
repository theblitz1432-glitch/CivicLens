generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Citizen {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  phone     String
  password  String
  block     String?
  pincode   String?
  district  String?  @default("Hisar")
  role      String   @default("citizen")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("citizens")
}

model Contractor {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String   @unique
  phone           String
  password        String
  companyName     String
  registrationNo  String   @unique
  address         String?
  licenseValidity String?
  specializations String[]
  role            String   @default("contractor")
  isApproved      Boolean  @default(false)
  avgRating       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("contractors")
}

model Authority {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String   @unique
  phone       String
  password    String
  designation String
  department  String
  block       String
  district    String   @default("Hisar")
  office      String?
  empCode     String?  @unique
  role        String   @default("authority")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("authorities")
}